<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the password is shown (checked = true) -->
    <item android:drawable="@drawable/ic_eye_visible" android:state_checked="true" android:tint="@color/secondary" />
    <!-- State when the password is hidden (default) -->
    <item android:drawable="@drawable/ic_eye_hidden" android:tint="@color/gray_400" />
</selector>