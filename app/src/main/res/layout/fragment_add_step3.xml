<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/add_new_recipe"
                android:textSize="22sp"
                android:textColor="@color/gray_900"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3/3"
                android:textSize="14sp"
                android:textColor="@color/gray_600"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="24dp"
            android:max="3"
            android:progress="3"
            android:progressTint="@color/purple_primary"
            android:progressBackgroundTint="@color/gray_200"/>

        <!-- Ingredients Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ingredients"
                        android:textSize="18sp"
                        android:textColor="@color/gray_900"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView
                        android:id="@+id/tvIngredientCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 selected"
                        android:textSize="13sp"
                        android:textColor="@color/purple_primary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvIngredientsError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"
                    android:text="Add at least one ingredient"/>

                <!-- Search with explicit button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.CookEase.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Search ingredients..."
                        app:startIconDrawable="@drawable/ic_search">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etIngredientSearch"
                            style="@style/Widget.CookEase.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearchIngredientsAdd"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:text="Search"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/purple_primary"/>
                </LinearLayout>

                <!-- Search Results -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvIngredientResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="220dp"
                    android:nestedScrollingEnabled="false"/>

                <!-- Selected Ingredients -->
                <TextView
                    android:id="@+id/tvSelectedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected"
                    android:textSize="14sp"
                    android:textColor="@color/gray_700"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSelectedIngredients"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Instructions Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/instructions"
                        android:textSize="18sp"
                        android:textColor="@color/gray_900"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView
                        android:id="@+id/tvStepCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 steps"
                        android:textSize="13sp"
                        android:textColor="@color/purple_primary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInstructionsError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"
                    android:text="Add at least one instruction step"/>

                <!-- Dynamic steps go here via RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInstructionSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

                <!-- Add Step Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddStep"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="+ Add Step"
                    android:textAllCaps="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackStep3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/back"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                style="@style/Widget.CookEase.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/submit_recipe"
                android:backgroundTint="@color/purple_primary"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
