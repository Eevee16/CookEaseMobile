<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top row: image + name + remove -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivSelectedIngredientImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:background="@color/gray_100"/>

            <TextView
                android:id="@+id/tvSelectedIngredientName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="14sp"
                android:textColor="@color/gray_900"
                android:fontFamily="sans-serif-medium"/>

            <ImageButton
                android:id="@+id/btnRemoveIngredient"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_card_white"
                android:src="@drawable/ic_close"
                android:contentDescription="Remove"
                android:padding="6dp"/>
        </LinearLayout>

        <!-- Qty + Unit row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.CookEase.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="Qty">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etIngredientQty"
                    style="@style/Widget.CookEase.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:maxLines="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Spinner
                android:id="@+id/spIngredientUnit"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_spinner"
                android:padding="12dp"/>
        </LinearLayout>

        <!-- Prep row -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CookEase.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Preparation (optional, e.g. minced)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etIngredientPrep"
                style="@style/Widget.CookEase.TextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"/>
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>